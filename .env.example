# Evolution API — local Docker configuration
# Copy to .env and adjust values before starting:
#   copy .env.example .env

# Public URL used by Evolution API (QR codes, webhooks, internal links)
SERVER_URL=http://localhost:8080

# Master API key — required on every Evolution API request (header: apikey)
AUTHENTICATION_API_KEY=change-me-to-a-secure-random-key

# Evolution API database (PostgreSQL service in docker-compose.yml)
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:change-me-postgres-password@postgres:5432/evolution?schema=public
DATABASE_CONNECTION_CLIENT_NAME=mrv4ult_evolution

# Postgres container credentials (must match DATABASE_CONNECTION_URI)
POSTGRES_DATABASE=evolution
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=change-me-postgres-password

# Disable Redis for local development
CACHE_REDIS_ENABLED=false

# Logging verbosity: ERROR, WARN, INFO, DEBUG
LOG_LEVEL=INFO

# MRV4ULT AI (Supabase) — used by Python app, not Evolution API
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
